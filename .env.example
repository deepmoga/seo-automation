# OpenAI API key (used for generating titles, meta descriptions, alt text,
# schema, SEO suggestions)
OPENAI_API_KEY=your_key_here

# Default WordPress credentials (used to seed the first site on first run;
# additional sites can be added/edited from the Sites page in the dashboard)
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_wp_application_password

# Port for the web dashboard (server.js)
PORT=4600

# Login credentials for the web dashboard
ADMIN_USER=admin
ADMIN_PASS=change_this_password

# Session secret - auto-generated on first run, do not edit
SESSION_SECRET=

# Google PageSpeed Insights API key (free - enable "PageSpeed Insights API"
# in Google Cloud Console). Used for Core Web Vitals checks.
PAGESPEED_API_KEY=
# Number of pages to check per "PageSpeed Check" run (default 5)
PAGESPEED_MAX_PAGES=5

# Telegram bot alerts (optional) - create a bot via @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP) alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=

# Google OAuth credentials (optional) - for Search Console integration.
# Create an OAuth 2.0 Client ID in Google Cloud Console with redirect URI:
#   https://your-domain.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
